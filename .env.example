# =============================================================================
# Tindivo 2.0 — Plantilla de variables de entorno
# Copia este archivo a `.env.local` en cada app que lo necesite.
# NUNCA commitees `.env.local` (ya está en .gitignore).
# Proyecto Supabase v2: "Web v2" (ref: psjigdoinfpgrnedxeyf)
# =============================================================================

# --- Supabase (público, expuesto al browser) ---
NEXT_PUBLIC_SUPABASE_URL="https://psjigdoinfpgrnedxeyf.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<publishable_anon_key>"

# --- Supabase (servidor, SECRETO — solo apps/api e Edge Functions) ---
SUPABASE_SERVICE_ROLE_KEY="<service_role_key>"

# --- URLs de la plataforma ---
# API REST única consumida por las 4 apps frontend
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
# URL pública de la app actual (para callbacks de auth, tracking links, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Inngest (scheduling) ---
INNGEST_SIGNING_KEY="<inngest_signing_key>"
INNGEST_EVENT_KEY="<inngest_event_key>"

# --- Web Push / VAPID ---
# Genera el par con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="<vapid_public_key>"
VAPID_PRIVATE_KEY="<vapid_private_key>"
VAPID_SUBJECT="mailto:soporte@tindivo.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="<vapid_public_key>"

# --- Rate limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL="<upstash_url>"
UPSTASH_REDIS_REST_TOKEN="<upstash_token>"

# --- Observabilidad (opcional en dev) ---
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
